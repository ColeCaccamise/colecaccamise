              <li><a href="b446666823b183e64d961e7f5194797a">Blog</a></li>
              <li><a href="contact">Contact</a></li>
            </ul>
          </div>

            
        </div>

        <div class="line"></div>
        <p class="copyright">&copy; <span id="year"></span> <a href="/"><span class="footer-name">Cole Caccamise</span></a></p>
