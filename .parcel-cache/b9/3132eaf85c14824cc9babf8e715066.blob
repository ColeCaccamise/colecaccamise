0;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap\");\n@import \"variables\";\n@import \"util\";\n\n@import \"components/navbar\";\n\n@import \"components/card\";\n\n@import \"components/footer\";\n\n@import \"sections/hero\";\n@import \"sections/about\";\n@import \"sections/portfolio\";\n@import \"sections/contact\";\n@import \"sections/links\";\n@import \"sections/wallpapers\";\n\n// Reset styles\n*,\n*::after,\n*::before {\n  margin: 0;\n  padding: 0;\n  box-sizing: inherit;\n}\n\nhtml {\n  font-size: 62.5%; // setting the root font size to be used with rem\n  scroll-behavior: smooth;\n}\n\nbody {\n  background-color: $bg-color;\n  color: $text-color;\n  box-sizing: border-box;\n  line-height: 1.7;\n  font-family: \"Poppins\", sans-serif;\n}\n\nh1,\nh2,\nh3,\nh4,\nh5,\nh6 {\n  color: $white-color;\n}\n\nul {\n  list-style: none;\n}\n\na {\n  text-decoration: none;\n  color: $link-color;\n\n  &:hover {\n    color: $hover-color-white;\n  }\n}\n\n.tag {\n  font-size: 1.2rem;\n}\n\n.nohover {\n  pointer-events: none;\n}\n\ni {\n  color: $text-color;\n}\n\np {\n  font-size: 1.6rem;\n  color: $text-color;\n}\n\nmain {\n  min-height: calc(100vh - 22rem);\n  padding-top: 9rem;\n}\n\n.container {\n  max-width: 119rem;\n  width: 85%;\n  margin: 2.5rem auto;\n\n  h1 {\n    font-size: 4.5rem;\n  }\n\n  h2 {\n    font-size: 2.5rem;\n  }\n}\n\nsection {\n  padding: 5rem 0;\n}\n\n@media (max-width: 1000px) {\n  .container {\n    width: 90%;\n  }\n}\n\n@media (max-width: 550px) {\n  .container {\n    width: 85%;\n    h1 {\n      font-size: 4rem;\n    }\n  }\n}\n\n@media (max-width: 380px) {\n  .container {\n    h1 {\n      font-size: 3.3rem;\n    }\n    p {\n      font-size: 1.5rem;\n    }\n  }\n}\n\n@media (max-width: 360px) {\n  .container h1 {\n    font-size: 3rem;\n  }\n  .line {\n    margin-top: 3rem;\n  }\n  .p-email {\n    margin-bottom: 1rem;\n  }\n}\n\n@media (max-height: 740px) {\n  .container-center {\n    height: 60%;\n  }\n}\n\n@media (max-height: 600px) {\n  .container-center {\n    height: 70%;\n  }\n}\n",".break {\n  display: block;\n}\n\n.hidden {\n  display: none;\n}\n\n.bold {\n  font-weight: 700;\n  letter-spacing: 1.1;\n\n  &-white {\n    color: $white-color;\n    font-weight: 600;\n  }\n}\n\n.box-shadow {\n  box-shadow: $box-shadow;\n}\n\n.line {\n  border: 1px solid $text-color;\n  opacity: 0.7;\n  width: 100%;\n  border-radius: $radius;\n  margin: auto;\n}\n\n.underline {\n  text-decoration: underline;\n\n  &-white {\n    color: $white-color;\n  }\n}\n\n.btn {\n  padding: 1rem 2rem;\n  border-radius: $radius;\n  margin-right: 2rem;\n  font-weight: 500;\n  font-size: 1.6rem;\n  transition: all 0.2s ease;\n  box-shadow: $box-shadow;\n  display: inline-block;\n\n  &:hover {\n    transform: translateY(-1px);\n  }\n\n  &:active {\n    transform: translateY(1px);\n  }\n\n  &--black {\n    background-color: black;\n    color: $white-color;\n  }\n\n  &--primary {\n    background: $white-color;\n    color: black;\n\n    &:hover {\n      color: rgba(0, 0, 0, 0.7);\n      background-color: $hover-color-white;\n    }\n  }\n\n  &--secondary {\n    border: 1px solid $white-color;\n    color: $white-color;\n  }\n}\n\n.container-center {\n  display: flex;\n  height: 50%;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n}\n\n.flex {\n  display: flex;\n}\n","@import url(\"https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap\");\n.break {\n  display: block;\n}\n.hidden {\n  display: none;\n}\n.bold {\n  font-weight: 700;\n  letter-spacing: 1.1;\n}\n.bold-white {\n  color: #f9f9fb;\n  font-weight: 600;\n}\n.box-shadow {\n  box-shadow: rgba(0, 0, 0, 0.75) 0px 5px 15px;\n}\n.line {\n  border: 1px solid rgba(255, 255, 255, 0.7);\n  opacity: 0.7;\n  width: 100%;\n  border-radius: 6px;\n  margin: auto;\n}\n.underline {\n  text-decoration: underline;\n}\n.underline-white {\n  color: #f9f9fb;\n}\n.btn {\n  padding: 1rem 2rem;\n  border-radius: 6px;\n  margin-right: 2rem;\n  font-weight: 500;\n  font-size: 1.6rem;\n  transition: all 0.2s ease;\n  box-shadow: rgba(0, 0, 0, 0.75) 0px 5px 15px;\n  display: inline-block;\n}\n.btn:hover {\n  transform: translateY(-1px);\n}\n.btn:active {\n  transform: translateY(1px);\n}\n.btn--black {\n  background-color: black;\n  color: #f9f9fb;\n}\n.btn--primary {\n  background: #f9f9fb;\n  color: black;\n}\n.btn--primary:hover {\n  color: rgba(0, 0, 0, 0.7);\n  background-color: rgba(255, 255, 255, 0.8);\n}\n.btn--secondary {\n  border: 1px solid #f9f9fb;\n  color: #f9f9fb;\n}\n.container-center {\n  display: flex;\n  height: 50%;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n}\n.flex {\n  display: flex;\n}\n.navbar {\n  position: fixed;\n  width: 100%;\n  background: #212121;\n  z-index: 99;\n  transition: all 0.6s ease;\n  transition: visibility 0.6s ease;\n}\n.navbar .hamburger {\n  display: none;\n  font-size: 2rem;\n}\n.navbar .hamburger i {\n  color: #f9f9fb;\n}\n.navbar .hamburger i:hover {\n  color: rgba(255, 255, 255, 0.8);\n}\n.navbar .hamburger i:active {\n  opacity: 0.9;\n}\n.navbar .flex {\n  display: flex;\n}\n.navbar__container {\n  display: flex;\n  justify-content: space-between;\n}\n.navbar__container a {\n  font-size: 1.6rem;\n}\n.navbar__menu {\n  display: flex;\n}\n.navbar__menu li {\n  padding: 1rem;\n}\n.navbar__menu .btn {\n  display: inline;\n}\n.navbar__menu a {\n  font-weight: 600;\n}\n.navbar__menu a:hover {\n  border-bottom: 1px solid black;\n}\n.navbar__logo {\n  cursor: pointer;\n  font-weight: 700;\n  color: #f9f9fb;\n  text-align: center;\n}\n.navbar__logo a {\n  color: #f9f9fb;\n  font-size: 3rem;\n}\n.navbar__logo a:hover {\n  color: rgba(255, 255, 255, 0.8);\n}\n.navbar__logo__top-section {\n  display: flex;\n  align-items: center;\n}\n.navbar__logo__menu {\n  flex-direction: column;\n  display: none;\n}\n.navbar__logo__menu .btn {\n  display: block;\n}\n@media (max-width: 900px) {\n  .navbar__container.container {\n    flex-direction: column;\n    margin: 1.5rem auto;\n  }\n  .navbar__top-section {\n    display: flex;\n    align-items: center;\n    padding-bottom: 1rem;\n  }\n  .navbar .hamburger {\n    display: block;\n    margin-right: 2rem;\n  }\n  .navbar__menu {\n    flex-direction: column;\n    display: none;\n  }\n  .navbar__menu .btn {\n    display: block;\n  }\n  .navbar__menu li:hover:not(:last-child) {\n    background: #4b4b4b;\n  }\n  .navbar__menu li:hover:not(:last-child) a {\n    color: rgba(255, 255, 255, 0.8);\n  }\n  .navbar__menu li:hover:not(:last-child) a:hover {\n    border: none;\n  }\n}\n@media (max-width: 500px) {\n  .navbar__logo a {\n    font-size: 2.8rem;\n  }\n}\n.cards {\n  display: flex;\n}\n.cards .card {\n  background-color: white;\n  margin: 0 1.1rem;\n  padding: 3rem;\n  text-align: left;\n  border-radius: 6px;\n  width: 33%;\n}\n.cards .card__img img {\n  width: 100%;\n}\n.cards .card h3 {\n  color: black;\n  font-size: 2.2rem;\n}\n.cards .card__description {\n  color: black;\n  margin-bottom: 2rem;\n}\n.cards .card .underline {\n  color: black;\n}\n.cards .card .underline:hover {\n  color: rgba(0, 0, 0, 0.7);\n}\n.cards .card__cta {\n  font-size: 1.5rem;\n  font-weight: 500;\n}\n.cards .card__cta:hover {\n  text-decoration: underline;\n  color: gray;\n}\n.cards .card__icons {\n  display: flex;\n  margin-bottom: 1.5rem;\n}\n.cards .card__icon {\n  font-size: 3.8rem;\n  margin-right: 1.5rem;\n}\n.cards .card__icon i {\n  color: gray;\n}\n.cards .card__icon i:hover {\n  color: black;\n}\n.cards .card__subheading {\n  color: black;\n  font-size: 1.7rem;\n}\n.cards .card__list {\n  list-style: disc;\n  padding-left: 1.7rem;\n  margin-bottom: 2rem;\n}\n.cards .card__list-container {\n  display: flex;\n  justify-content: space-between;\n}\n.cards .card__list li {\n  color: black;\n  font-size: 1.4rem;\n}\n@media (max-width: 1350px) {\n  .card__list-container {\n    flex-direction: column;\n  }\n}\n@media (max-width: 1090px) {\n  .cards {\n    flex-direction: column;\n  }\n  .cards .card {\n    width: 100%;\n    margin: 1rem 0;\n    text-align: center;\n  }\n  .cards .card__list li {\n    list-style: none;\n  }\n  .cards .card__icons {\n    justify-content: center;\n  }\n  .cards .card__list {\n    padding-left: 0;\n  }\n  .cards .card__list-container {\n    flex-direction: row;\n    justify-content: center;\n  }\n  .cards .card__list-container div {\n    padding: 1rem;\n    display: flex;\n    flex-direction: column;\n    width: 20rem;\n  }\n  .cards .card__list-container div li {\n    list-style: none;\n  }\n}\n@media (max-width: 500px) {\n  .cards .card {\n    padding: 2.5rem;\n  }\n  .cards .card__description {\n    margin-bottom: 1rem;\n  }\n  .cards .card__list-container {\n    flex-direction: column;\n    align-items: center;\n  }\n}\n@media (max-width: 450px) {\n  .cards .card {\n    width: 90%;\n    margin-left: auto;\n    margin-right: auto;\n  }\n}\n.footer__container {\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  align-items: space-between;\n}\n.footer__content {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n.footer .copyright {\n  text-align: center;\n  padding: 2rem 0;\n  font-size: 1.6rem;\n}\n.footer-name {\n  color: #f9f9fb;\n}\n.footer-name:hover {\n  color: rgba(255, 255, 255, 0.8);\n}\n.footer__icon i {\n  font-size: 2.7rem;\n  margin-right: 1rem;\n  color: #f9f9fb;\n}\n.footer__icon i:hover {\n  color: rgba(255, 255, 255, 0.8);\n}\n@media (max-width: 425px) {\n  .footer__icon i {\n    font-size: 3rem;\n  }\n  .footer__content {\n    flex-direction: column;\n  }\n  .footer__content p {\n    font-size: 1.8rem;\n  }\n}\nh1 {\n  font-weight: 600;\n  font-size: 6rem;\n  line-height: 6rem;\n}\n.hero__container {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n.hero__text-wrapper {\n  display: flex;\n  f