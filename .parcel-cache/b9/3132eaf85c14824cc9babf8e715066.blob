     padding: 2.5rem;\n      &__description {\n        margin-bottom: 1rem;\n      }\n\n      &__list-container {\n        flex-direction: column;\n        align-items: center;\n      }\n    }\n  }\n}\n\n@media (max-width: 450px) {\n  .cards {\n    .card {\n      width: 90%;\n      margin-left: auto;\n      margin-right: auto;\n    }\n  }\n}\n","// Footer\n.footer {\n  &__container {\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: space-between;\n  }\n\n  &__content {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n  }\n\n  .copyright {\n    text-align: center;\n    padding: 2rem 0;\n    font-size: 1.6rem;\n  }\n\n  &-name {\n    color: $white-color;\n\n    &:hover {\n      color: $hover-color-white;\n    }\n  }\n\n  &__icon i {\n    font-size: 2.7rem;\n    margin-right: 1rem;\n    color: $white-color;\n\n    &:hover {\n      color: $hover-color-white;\n    }\n  }\n}\n\n@media (max-width: 425px) {\n  .footer {\n    &__icon {\n      i {\n        font-size: 3rem;\n      }\n    }\n\n    &__content {\n      flex-direction: column;\n\n      p {\n        font-size: 1.8rem;\n      }\n    }\n  }\n}\n","// Hero section\nh1 {\n  font-weight: 600;\n  font-size: 6rem;\n  line-height: 6rem;\n}\n\n.hero__container {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.hero__text-wrapper {\n  display: flex;\n  flex-direction: column;\n  gap: $hero-gap;\n}\n\n.hero__copy {\n  width: 42rem;\n  line-height: 1.5;\n\n  p {\n    font-size: 1.9rem;\n    line-height: 3.5rem;\n    letter-spacing: 0.7;\n  }\n}\n\n.hero__cta-buttons {\n  margin: 10px 0;\n}\n\n@keyframes updown {\n  0% {\n    transform: translateY(0);\n  }\n\n  100% {\n    transform: translateY(1rem);\n  }\n}\n\n.chevron-container {\n  display: block;\n  text-align: center;\n  animation: updown infinite alternate 1.5s ease-in-out;\n\n  i {\n    font-size: 15px;\n  }\n}\n\n.hero__img {\n  width: 35rem;\n}\n\n.img--round {\n  border-radius: 50%;\n}\n\n@media (max-width: 1000px) {\n  .hero {\n    &__img {\n      width: 30rem;\n    }\n  }\n}\n\n@media (max-width: 880px) {\n  .hero {\n    &__container {\n      flex-direction: column-reverse;\n    }\n\n    // &__main {\n    //   padding-top: 4rem;\n    // }\n\n    &__img {\n      margin-bottom: 4rem;\n    }\n  }\n}\n\n@media (max-width: 550px) {\n  #hero {\n    padding: 1rem 0 4.5rem 0;\n  }\n\n  .hero {\n    &__text-wrapper {\n      gap: 1rem;\n    }\n\n    &__cta-buttons {\n      margin-bottom: 0;\n    }\n\n    &__img {\n      width: 30rem;\n      margin-bottom: 3rem;\n    }\n\n    &__copy {\n      width: 100%;\n      p {\n        font-size: 1.7rem;\n        line-height: 3rem;\n      }\n    }\n  }\n}\n\n@media (max-width: 380px) {\n  .hero {\n    &__copy {\n      font-size: 1.6rem;\n    }\n    &__img {\n      width: 18rem;\n      margin-bottom: 0.5rem;\n    }\n    &__cta-buttons {\n      .btn--primary {\n        margin-bottom: 1.5rem;\n      }\n    }\n    // &__container {\n    //   .hero__text-wrapper {\n    //     h1 {\n    //       font-size: 3rem;\n    //       line-height: 1.5;\n    //     }\n    //   }\n    // }\n\n    &__cta-buttons {\n      .btn {\n        margin-right: 1rem;\n      }\n    }\n  }\n}\n\n@media (max-width: 400px) {\n  .hero {\n    &__img {\n      width: 25rem;\n    }\n    &__text-wrapper {\n      h1 {\n        font-size: 3.3rem;\n        line-height: 1.5;\n      }\n    }\n  }\n}\n\n@media (max-width: 360px) {\n  .hero {\n    &__img {\n      display: none;\n    }\n  }\n}\n","// About\n#about {\n  .about {\n    &__container {\n      text-align: center;\n    }\n\n    &__heading {\n      display: flex;\n      justify-content: space-evenly;\n      font-size: 2.8rem;\n    }\n\n    &__subheading {\n      font-size: 2rem;\n      color: gray;\n      line-height: 1;\n    }\n\n    &__text {\n      margin: 2rem 0;\n\n      p {\n        line-height: 1.6;\n      }\n    }\n  }\n}\n\n@media (max-width: 1000px) {\n  #about {\n    padding: 3rem 0;\n  }\n}\n","// Portfolio\n.portfolio {\n  &__container {\n    text-align: center;\n  }\n\n  h2 {\n    text-align: left;\n  }\n\n  .cards {\n    margin: 2rem auto;\n  }\n\n  .card {\n    // margin: 0;\n    // margin-right: 1rem;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n\n    &__buttons {\n      display: flex;\n\n      .btn:last-child {\n        margin-right: 0;\n      }\n    }\n\n    .btn {\n      i {\n        color: $white-color;\n        font-size: 2.4rem;\n        text-align: center;\n      }\n    }\n  }\n}\n","// contact\n.contact__container {\n  text-align: center;\n\n  h1 {\n    font-size: 4.5rem;\n  }\n  .contact__form {\n    text-align: center;\n    max-width: 50%;\n    margin: 2rem auto;\n\n    input,\n    textarea {\n      width: 100%;\n\n      margin: 0.8rem 0;\n      box-shadow: $box-shadow;\n      background: white;\n      padding: 1rem;\n      border: 1px solid transparent;\n      -webkit-appearance: none;\n      font-family: \"Poppins\", sans-serif;\n      border-radius: $radius;\n      font-size: 1.6rem;\n    }\n\n    textarea {\n      height: 10rem;\n      border-radius: 9px;\n      padding: 16px;\n      resize: vertical;\n      min-height: 5rem;\n    }\n\n    .btn {\n      font-family: \"Poppins\", sans-serif;\n      margin: 2rem 0;\n      outline: none;\n      border: 1px solid transparent;\n\n      i {\n        color: black;\n      }\n\n      &:hover {\n        i {\n          color: gray;\n        }\n      }\n    }\n  }\n}\n\n// success\n.success__container {\n  h1 {\n    font-size: 5rem;\n  }\n\n  p {\n    font-size: 1.8rem;\n  }\n\n  .fa-check-circle {\n    font-size: 7rem;\n    color: green;\n    border-radius: 50%;\n    transform: scale(1.1);\n  }\n\n  .fa-frown-open {\n    font-size: 7rem;\n  }\n\n  .icon-container {\n    background: white;\n    border-radius: 50%;\n    margin: 1rem;\n  }\n\n  .icon-success {\n    color: white;\n    overflow: hidden;\n\n    // &::before {\n    //   background-color: $white-color;\n    //   background-repeat: no-repeat;\n    //   vertical-align: middle;\n    //   border-radius: 50%;\n    // }\n  }\n  .icon-circle {\n    color: green;\n    overflow: hidden;\n  }\n\n  .icon-return {\n    color: $bg-color;\n    margin-right: 4px;\n  }\n\n  .btn {\n    margin: 2rem;\n  }\n}\n\n@media (max-width: 900px) {\n  .contact__container .contact__form {\n    max-width: 100%;\n  }\n}\n\n@media (max-width: 415px) {\n  .contact__container .contact__form {\n    max-width: 90%;\n  }\n}\n","// Links\n.links {\n  padding: 0;\n\n  &__heading {\n    font-size: 3rem !important;\n  }\n\n  &__container {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n\n  &__card {\n    background-color: rgba(0, 0, 0, 0.05);\n    padding: 2rem;\n    margin: 2rem auto;\n    width: 50rem;\n    text-align: center;\n    border-radius: 9px;\n    box-shadow: $box-shadow;\n\n    h3 {\n      font-size: 18px;\n      font-weight: 500;\n    }\n\n    p {\n      font-size: 16px;\n    }\n  }\n\n  .link {\n    padding: 2rem;\n    width: 100%;\n    border-bottom: 1px solid rgba(255, 255, 255, 0.6);\n\n    &:last-child {\n      border-bottom: none;\n    }\n\n    &:hover {\n      background: rgba(0, 0, 0, 0.2);\n    }\n  }\n\n  .vid-container {\n    position: relative;\n    width: 100%;\n    height: 0;\n    padding-bottom: 56.25%;\n    margin: 1rem 0;\n  }\n  .video {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n  }\n\n  &__heading {\n    font-size: 22px;\n    line-height: 1.5;\n  }\n\n  &__img {\n    width: 15rem;\n    border-radius: 50%;\n    margin-bottom: 1rem;\n  }\n}\n\n@media (max-width: 560px) {\n  .links {\n    &__card {\n      width: 100%;\n    }\n  }\n}\n","// wallpapers\n.wallpapers {\n  text-align: center;\n\n  .wallpaper {\n    text-align: left;\n    margin: auto;\n  }\n\n  img {\n    width: 100%;\n    margin-top: 1rem;\n  }\n\n  &__buttons {\n    .btn {\n      margin: 2rem 0 1rem 0;\n      display: inline-block;\n    }\n  }\n}\n"],"names":[],"version":3,"file":"index.HASH_REF_745cc34b358837c64bb359ffdddda9d0.css.map"}