                  <i class="fas fa-chevron-down"></i>
                </div>
                
              </div>
            
          </section>

          <!-- About -->
          <section id="about">
            <div class="container about-container">
            <div class="about-summary">
              <h2>About Me.</h2>
              <h3 class="about-subheading">Passionate creator, dev, designer</h3>
          </div>

          <div class="about-text"><p>I'm a 17 year old content creator from <span class="bold">Buffalo, NY</span>. I enjoy making videos about my favorite tech products and share my honest thoughs in an entertaining yet straight-forward way. I also like to build and design websites on the side. I'm mostly a front-end guy but want to dive deeper in the future.</p></div>
            

            <!-- about cards -->
            <div class="cards">

              <div class="card">
                <div class="card-icons"></div>

                <h4>Content Creator</h4>
                <p class="card-description">
                  Lorem ipsum dolor sit, amet consectetur adipisicing elit. Est incidunt animi repellat!
                </p>
                <a href="#" class="cta">My Gear & Equipment -></a>
              </div>
              
              <div class="card">
                <div class="card-icons"></div>

                <h4>Web Developer</h4>
                  <p class="card-description">
                    Lorem ipsum dolor sit, amet consectetur adipisicing elit. Est incidunt animi repellat!
                  </p>
                  <a href="#" class="cta">See my projects -></a>
              </div>

              <div class="card">
                <div class="card-icons"></div>

                <h4>Designer</h4>
                <p class="card-description">
                  Lorem ipsum dolor sit, amet consectetur adipisicing elit. Est incidunt animi repellat!
                </p>
                <a href="#" class="cta">See my work -></a>
              </div>


            </div>
          </div>
          </section>

          <!-- Contact CTA section -->
      </main>

      <!-- Footer -->
