<body>
    
    <!-- Navbar -->
    <header>
        <nav class="navbar">
          <div class="container navbar-container">
            <div class="logo"><a href="/">cole caccamise.</a></div>
            <div class="nav-links">
              <ul class="menu">
                <li><a href="/#about">About</a></li>
                <li><a href="/links">Links</a></li>
