        </div>
        </nav>
      </header>

      <main>
          <!-- main elements here -->

          <!-- Hero -->
          <section id="hero">
              <div class="container hero-container">

                <div class="hero-text-wrapper">
                  <div class="hero-heading">
                    <h1><span class="break">Tech</span> <span class="break"></span>Content Creator.</h1>
                  </div>
                    <div class="hero-copy">
                    <p>I talk about the tech I’m passionate about, but also like to design and code on the side.</p>
                  </div>
                  
                    <div class="hero-cta-buttons">
                        <a href="" class="btn btn-primary">Get in touch ></a>
                        <a href="#about" class="btn btn-secondary">Learn more</a>
                    </div>
                </div>
              
                <div class="hero-img-wrapper">
                    <img class="hero-img round-img" src="516902d3134f716cf9b6da66fa5b22a6" alt="cole caccamise">
                </div>

                <!-- animated chevron placeholder -->
