      </header>

      <main class="hero__main">
          <!-- main elements here -->

          <!-- Hero -->
          <section id="hero">
              <div class="container hero__container">

                <div class="hero__text-wrapper">
                  <div class="hero__heading">
                    <h1><span class="break">Tech</span> <span class="break"></span>Content Creator.</h1>
                    
                  </div>
                    <div class="hero__copy">
                    <p>Sharing my thoughts on the latest tech through the internet. I also enjoy coding and designing websites.</p>
                  </div>
                  
                    <div class="hero__cta-buttons">
                        <a href="contact" class="btn btn--primary">Get in touch ></a>
                        <a href="#about" class="btn btn--secondary">Learn more</a>
                    </div>
                </div>
              
                <div class="hero__img-wrapper">
                    <img class="hero__img img--round" src="2512dba3b9639bd45b8fb1c3c70e18e1" alt="cole caccamise">
