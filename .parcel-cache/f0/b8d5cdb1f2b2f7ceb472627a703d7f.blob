          <!-- About -->
          <section id="about">
            <div class="container about__container">
            <div class="about__summary">
              <h2 class="about__heading">About Me.</h2>
              <h3 class="about__subheading">Passionate creator, dev, & designer</h3>
          </div>

          <div class="about__text"><p>I'm a 17 year old content creator from <span class="bold-white">Buffalo, NY</span>. I enjoy making videos about my favorite tech products, sharing my honest thoughts in an entertaining and straightforward way. I also like to build and design websites on the side. I'm mostly interested in the front-end but plan on diving deeper in the future.</p></div>
            

            <!-- about cards -->
            <div class="cards">

              <div class="card">
                <div class="card__icons">
                  <a href="ea8f8401e0489699ee7183dd97b9d647" class="card__icon">
                    <i class="fab fa-youtube"></i>
                  </a>
                  <a href="5de245af6a88679c7038b9ccff856f72" class="card__icon">
                  <i class="fab fa-twitter"></i>
                </a>
                  <a href="957d41d568be236fa82fb3bb48fd67b6" class="card__icon">
                    <i class="fab fa-instagram"></i>
                  </a>
                  
                  <a href="3ff492570c06cfff72e7c67d73028e2a" class="card__icon">
                  <i class="fab fa-twitch"></i>
                    </a>

                </div>

                <h3>Content Creator</h3>
                <p class="card__description">
                  I make videos and take photos of tech produtcts I love using.
                </p>
                <p class="card__description">
                 I go for a cinematic sort of style, and am always improving the quality of what I put out.
                </p>
                <p class="card__description">
                  Follow me to watch my journey
                 </p>
                <a href="16df40ee1f10de9361742227537e61b1" class="card__cta">My Gear & Equipment -></a>
              </div>
              
              <div class="card">
                <div class="card__icons">
                  <a href="24d0d98456ffb8ff29b51c687963ebf1" class="card__icon">
                    <i class="fab fa-github"></i>
                    </a>
                    <a href="portfolio" class="card__icon">              
                      <i class="fas fa-laptop-code"></i>
                      </a>
                </div>


                <h3>Web Developer</h3>
                  <p class="card__description">
                    I'm a self-taught web developer. I enjoy working on the front-end most, and recently I've been brushing up on my skills in JavaScript and CSS.
                  </p>

                  <div class="card__list-container">
                    <div>
                      <h4 class="card__subheading">Languages</h4>
                  <ul class="card__list">
                    <li>HTML</li>
                    <li>CSS</li>
                    <li>JavaScript</li>
                    <li>Shopify Liquid</li>
                  </ul>
                    </div>
                    
                    <div>
