@import url("https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap");
*,
*::after,
*::before {
  margin: 0;
  padding: 0;
  box-sizing: inherit;
}
html {
  font-size: 62.5%;
  /* setting the root font size to be used with rem */
}
body {
  background-color: #212121;
  color: #a6a5a3;
  box-sizing: border-box;
  line-height: 1.7;
  font-family: "Poppins", sans-serif;
}
h1,
h2,
h3,
h4,
h5,
h6 {
  color: #f9f9fb;
}
ul {
  list-style: none;
}
a {
  text-decoration: none;
  color: #888888;
}
a:hover {
  color: rgba(255, 255, 255, 0.6);
}
.container {
  max-width: 119rem;
  margin: 2.5rem auto;
}
.break {
  display: block;
}
section {
  padding: 5rem 0;
}
.navbar-container {
  display: flex;
  justify-content: space-between;
}
.navbar-container a {
  font-size: 1.6rem;
}
.menu {
  display: flex;
}
.menu li {
  padding: 0.7rem;
}
.menu a {
  font-weight: 600;
}
.menu a:hover {
  border-bottom: 1px solid black;
}
.logo {
  cursor: pointer;
  font-weight: 700;
  color: #f9f9fb;
  text-align: center;
}
.logo a {
  color: #f9f9fb;
  font-size: 3rem;
}
.logo a:hover {
  color: rgba(255, 255, 255, 0.85);
}
h1 {
  font-weight: 600;
  font-size: 6rem;
  line-height: 7rem;
}
.hero-container {
  display: flex;
  justify-content: space-between;
}
.hero-text-wrapper {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}
.hero-copy {
  width: 42rem;
  line-height: 1.5;
}
.hero-copy p {
  font-size: 1.9rem;
  line-height: 3.5rem;
  letter-spacing: 0.7;
}
.hero-cta-buttons {
  margin: 10px 0;
}
.btn {
  padding: 1rem 1.5rem;
  border-radius: 6px;
  margin-right: 10px;
  font-weight: 500;
  font-size: 1.6rem;
}
.btn-primary {
  background: #f9f9fb;
  color: black;
}
.btn-primary:hover {
  color: rgba(0, 0, 0, 0.7);
}
.btn-secondary {
  border: 1px solid #f9f9fb;
  color: white;
}
.hero-img {
  width: 350px;
}
.round-img {
  border-radius: 50%;
}
#about .about-container {
  text-align: center;
}
#about .about-heading {
  display: flex;
  justify-content: space-evenly;
}
#about .about-text {
  margin: 20px 0;
}
#about .about-text p {
  line-height: 1.6;
}
#about h2 {
  font-size: 35px;
  font-weight: 600;
  margin-bottom: 10px;
}
#about h3 {
  font-size: 20px;
  color: gray;
}