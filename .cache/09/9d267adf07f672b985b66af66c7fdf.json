ainer hero__container\">\n\n                <div class=\"hero__text-wrapper\">\n                  <div class=\"hero__heading\">\n                    <p class=\"hero__intro\">I'm a</p>\n                    <h1>Video Creator, <span class=\"break\"></span>\n                    Developer,<span class=\"break\"></span>\n                    & Designer</h1> \n                    <p class=\"hero__intro\">Based in <span class=\"bold\">Buffalo, NY</span>.</p>\n                    \n                  </div>\n                    <div class=\"hero__copy\">\n                    <p>Sharing my thoughts on the latest tech in an honest and entertaining fashion. I also enjoy building & designing websites and apps.</p>\n                   \n                  </div>\n                  \n                    <div class=\"hero__cta-buttons\">\n                        <a href=\"contact\" class=\"btn btn--primary btn-contact\">Get in touch ></a>\n                        <a href=\"#about\" class=\"btn btn--secondary\">Learn more</a>\n                    </div>\n                </div>\n              \n                <div class=\"hero__img-wrapper\">\n                    <img class=\"hero__img img--round\" src=\"/b5e4069e38119edd929c43e6c8fd42f2.webp\" loading=\"lazy\" alt=\"Cole Caccamise\">\n                </div>\n                \n              </div>\n            \n          </section>\n\n                          <!-- animated chevron placeholder -->\n                          <a href=\"#about\" class=\"chevron-container\" aria-label=\"scroll down\">\n                            <i class=\"fas fa-chevron-down\" aria-hidden=\"true\"></i>\n                          </a>\n          \n\n          <!-- About -->\n          <section id=\"about\">\n            <div class=\"container about__container\">\n            <div class=\"about__summary\">\n              <h2 class=\"about__heading\">About Me.</h2>\n              <h3 class=\"about__subheading\">A passionate creative with too many hobbies</h3>\n          </div>\n\n          <div class=\"about__text\"></div>\n            \n\n            <!-- about cards -->\n            <div class=\"cards\">\n\n              <div class=\"card\">\n                <div class=\"card__icons\">\n                  <a href=\"https://youtube.com/c/colecaccamise\" class=\"card__icon\" aria-label=\"YouTube\">\n                    <i class=\"fab fa-youtube\" aria-hidden=\"true\"></i>\n                  </a>\n                  <a href=\"https://twitter.com/colecaccamise\" class=\"card__icon\" aria-label=\"Twitter\">\n                  <i class=\"fab fa-twitter\" aria-hidden=\"true\"></i>\n                </a>\n                  <a href=\"https://instagram.com/cole.caccamise\" class=\"card__icon\" aria-label=\"Instagram\">\n                    <i class=\"fab fa-instagram\" aria-hidden=\"true\"></i>\n                  </a>\n                  \n                  <a href=\"https://twitch.tv/colecaccamise\" class=\"card__icon\" aria-label=\"Twitch\">\n                  <i class=\"fab fa-twitch\" aria-hidden=\"true\"></i>\n                    </a>\n\n                </div>\n\n                <h3>Content Creator</h3>\n                <p class=\"card__description\">\n                  When it comes to content, video is my thing. I love to review gadgets with a cinematic style and offer my insight from the perspective of a techie. \n                </p>\n\n                <p class=\"card__description\">\n                  Don't worry, I won't just throw numbers at you. I make it easy for the average consumer to understand and hopefully give you a few laughs.\n                </p>\n\n                <p class=\"card__description\">You can find me on all of the above platforms, and check out the gear I use to produce it all below.</p>\n                \n                <a href=\"http://kit.co/colecaccamise\" class=\"card__cta btn btn--black\">My Gear & Equipment ></a>\n              </div>\n              \n              <div class=\"card\">\n                <div class=\"card__icons\">\n                  <a href=\"https://github.com/colecaccamise\" class=\"card__icon\" aria-label=\"GitHub\">\n                    <i class=\"fab fa-github\" aria-hidden=\"true\"></i>\n                    </a>\n                    <a href=\"portfolio\" class=\"card__icon\" aria-label=\"Portfolio\">              \n                      <i class=\"fas fa-laptop-code\" aria-hidden=\"true\"></i>\n                      </a>\n                </div>\n\n\n                <h3>Web Developer</h3>\n                  <p class=\"card__description\">\n                    I'm a front-end web developer and current Computer Science B.S. student. I know how to build sites that are fast and can turn visitors into loyal customers.\n                  </p>\n\n                  <!-- <p class=\"card__description\">\n                    I work with clients at my agency <a href=\"https://websignr.com\">websignr</a>. More info can be found on the website.\n                  </p> -->\n\n                  <div class=\"card__list-container\">\n                    <div>\n                      <h4 class=\"card__subheading\">Languages I know</h4>\n                  <ul class=\"card__list\">\n                    <li>HTML</li>\n                    <li>CSS</li>\n                    <li>JavaScript</li>\n                    <li>Shopify Liquid</li>\n                  </ul>\n                    </div>\n                    \n                    <div>\n                      <h4 class=\"card__subheading\">Tools & Frameworks</h4>\n                      <ul class=\"card__list\">\n                        <li>Visual Studio Code</li>\n                        <li>GitHub</li>\n                        <li>NPM</li>\n                        <li>Parcel</li>\n                        <li>Sass / SCSS</li>\n                      </ul>\n                    </div>\n                  </div>\n\n                  <a href=\"portfolio\" class=\"card__cta btn btn--black\">See my projects ></a>\n              </div>\n\n              <div class=\"card\">\n                <div class=\"card__icons\">\n                  <a href=\"https://dribbble.com/colecaccamise\" class=\"card__icon\" aria-label=\"Dribbble\">\n                    <i class=\"fab fa-dribbble\" aria-hidden=\"true\"></i>\n                  </a>\n                  <a href=\"https://instagram.com/ui.cole\" class=\"card__icon\" aria-label=\"Instagram\">\n                    <i class=\"fab fa-instagram\" aria-hidden=\"true\"></i>\n                  </a>\n                </div>\n\n                <h3>Designer</h3>\n                <p class=\"card__description\">\n                  I enjoy designing minimal interfaces for web and mobile apps. I'm sharing some of my work online.\n                </p>\n\n                <p class=\"card__description\">I also like to design wallpapers <a class=\"underline \" href=\"/wallpapers\"><span class=\"break\"></span>(download here)</a></p>\n                <a href=\"portfolio\" class=\"card__cta btn btn--black\">See my work ></a>\n              </div>\n\n\n            </div>\n          </div>\n          </section>\n\n      </main>\n\n      <!-- Footer -->\n      <footer class=\"footer\">\n        <div class=\"container footer__container\">\n            \n        </div>\n      </footer>\n    \n    \n</body>\n</html>"},"sourceMaps":null,"error":null,"hash":"6b20a2854cc7d08264f9ac1c02799b0f","cacheData":{"env":{}}}